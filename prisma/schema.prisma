generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum UserStatus {
  active
  disabled
}

enum IntegrationProvider {
  azure_devops
}

enum ExportStatus {
  success
  failed
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(user)
  status             UserStatus          @default(active)
  forcePasswordReset Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  projects           Project[]
  loginAttempts      LoginAttempt[]
  createdIntegrations WorkspaceIntegration[] @relation("WorkspaceIntegrationCreatedBy")
  updatedIntegrations WorkspaceIntegration[] @relation("WorkspaceIntegrationUpdatedBy")
  exports            DevOpsExport[]
  workItemLinks      DevOpsWorkItemLink[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  rotatedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id        String    @id @default(cuid())
  ownerId   String
  name      String
  payload   Json
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  exports   DevOpsExport[]
  workItemLinks DevOpsWorkItemLink[]

  @@index([ownerId])
  @@index([isDeleted])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  ipAddress  String
  succeeded  Boolean  @default(false)
  attemptedAt DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, ipAddress, attemptedAt])
  @@index([attemptedAt])
}

model WorkspaceIntegration {
  id             String              @id @default(cuid())
  provider       IntegrationProvider
  organizationUrl String
  encryptedPat   String
  createdById    String
  updatedById    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      User                @relation("WorkspaceIntegrationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy      User                @relation("WorkspaceIntegrationUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)

  @@unique([provider])
}

model DevOpsExport {
  id              String     @id @default(cuid())
  ownerId         String
  projectId       String
  azureProjectName String
  epicWorkItemId  Int?
  status          ExportStatus
  summary         Json
  createdAt       DateTime   @default(now())
  owner           User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workItemLinks   DevOpsWorkItemLink[]

  @@index([ownerId, projectId])
}

model DevOpsWorkItemLink {
  id               String      @id @default(cuid())
  ownerId          String
  projectId        String
  azureProjectName String
  workItemId       Int
  workItemType     String
  logicalKey       String
  contentHash      String
  lastExportId     String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  owner            User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lastExport       DevOpsExport? @relation(fields: [lastExportId], references: [id], onDelete: SetNull)

  @@unique([ownerId, projectId, logicalKey])
  @@index([projectId, azureProjectName])
}
